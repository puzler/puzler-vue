    "@vueuse/core": "^14.3.0",
    "apollo-upload-client": "^17.0.0",
    "driver.js": "^1.6.0",
    "graphql": "^16.14.2",
    "graphql-ruby-client": "^1.15.1",
    "js-sha256": "^0.11.1",
    "lz-string": "^1.5.0",
    "pinia": "^3.0.4",
